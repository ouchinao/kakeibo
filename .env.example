# Kakeibo Engine configuration.
# Copy this file to ".env" and adjust as needed. The real ".env" is gitignored.

# HTTP server port for the API + web UI.
PORT=3000

# Path to the SQLite database file.
# Use ":memory:" for an ephemeral in-memory database (handy for local demos).
DATABASE_PATH=./data/kakeibo.sqlite

# Default currency used when a request does not specify one (ISO 4217 code).
# Supported out of the box: JPY, USD, EUR.
DEFAULT_CURRENCY=JPY
